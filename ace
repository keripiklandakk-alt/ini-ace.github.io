<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Selamat Ulang Tahun! 🎉</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            color: #333;
        }

        .card {
            background: rgba(255, 255, 255, 0.9);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            text-align: center;
            max-width: 400px;
            width: 90%;
            z-index: 10;
            transform: scale(0.9);
            animation: popIn 0.8s forwards cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes popIn {
            to { transform: scale(1); }
        }

        h1 {
            color: #ff6b81;
            margin-bottom: 10px;
            font-size: 2.5rem;
        }

        p {
            font-size: 1.1rem;
            line-height: 1.6;
            color: #555;
        }

        .btn {
            background-color: #ff6b81;
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 1rem;
            border-radius: 25px;
            cursor: pointer;
            transition: background 0.3s, transform 0.2s;
            margin-top: 20px;
            box-shadow: 0 5px 15px rgba(255, 107, 129, 0.4);
        }

        .btn:hover {
            background-color: #ff4757;
            transform: translateY(-2px);
        }

        .hidden-message {
            display: none;
            margin-top: 20px;
            padding: 15px;
            background: #fff0f2;
            border-left: 5px solid #ff6b81;
            border-radius: 5px;
            animation: fadeIn 0.5s forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Animasi Balon */
        .balloon {
            position: absolute;
            width: 50px;
            height: 65px;
            background: rgba(255, 107, 129, 0.8);
            border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
            bottom: -100px;
            animation: float Up 8s infinite ease-in;
            z-index: 1;
        }

        .balloon::before {
            content: "";
            position: absolute;
            bottom: -8px;
            left: 22px;
            width: 0;
            height: 0;
            border-left: 3px solid transparent;
            border-right: 3px solid transparent;
            border-bottom: 8px solid rgba(255, 107, 129, 0.8);
        }

        @keyframes floatUp {
            0% {
                bottom: -100px;
                transform: translateX(0) rotate(0deg);
            }
            50% {
                transform: translateX(50px) rotate(10deg);
            }
            100% {
                bottom: 110vh;
                transform: translateX(-50px) rotate(-10deg);
            }
        }
    </style>
</head>
<body>

    <!-- Balon Dekorasi -->
    <div class="balloon" style="left: 10%; background: #ff4757; animation-delay: 0s; animation-duration: 6s;"></div>
    <div class="balloon" style="left: 25%; background: #2ed573; animation-delay: 2s; animation-duration: 8s;"></div>
    <div class="balloon" style="left: 70%; background: #1e90ff; animation-delay: 1s; animation-duration: 7s;"></div>
    <div class="balloon" style="left: 85%; background: #ffa502; animation-delay: 3s; animation-duration: 9s;"></div>

    <div class="card">
        <h1>Happy Birthday! 🎂</h1>
        <p>Hari ini adalah hari yang spesial untukmu! Semoga di usia yang baru ini, kamu selalu dilimpahi kebahagiaan, kesehatan, dan kesuksesan dalam segala hal.</p>
        
        <button class="btn" onclick="tampilkanPesan()">Klik untuk Kejutan ✨</button>

        <div id="pesanRahasia" class="hidden-message">
            <p><strong>"Semoga semua impian dan cita-citamu segera terwujud. Terima kasih sudah menjadi orang yang luar biasa! Tetap semangat dan selalu tersenyum ya! 😊💖"</strong></p>
        </div>
    </div>

    <script>
        function tampilkanPesan() {
            var pesan = document.getElementById("pesanRahasia");
            var tombol = document.querySelector(".btn");
            
            if (pesan.style.display === "none" || pesan.style.display === "") {
                pesan.style.display = "block";
                tombol.innerText = "Tutup Pesan 🎈";
            } else {
                pesan.style.display = "none";
                tombol.innerText = "Klik untuk Kejutan ✨";
            }
        }
    </script>
</body>
</html>
